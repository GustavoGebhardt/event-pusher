# Lambda environment variables (managed via SAM parameters, not .env)
# This file documents what each env var controls.

GOOGLE_SECRET_NAME=event-pusher/google-credentials  # Secrets Manager key
DEFAULT_TITLE=Ocupado                                # Title when not provided
DEFAULT_TIMEZONE=America/Sao_Paulo
MIN_DURATION_MINUTES=5
MAX_DURATION_HOURS=8
MAX_FUTURE_DAYS=365
ALLOW_PAST_EVENTS=false                              # Set true to allow retroactive events
